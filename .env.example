VITE_RPC_URL=http://127.0.0.1:8545
VITE_CHAIN_ID=31337
VITE_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
# Optional: replace demo with your WalletConnect project id
VITE_WALLETCONNECT_PROJECT_ID=demo
# Sepolia (11155111): set a dedicated HTTPS RPC so wagmi/RainbowKit do not use viem's default thirdweb URL (429 + CORS noise in the browser). Overrides the public fallback when set.
# VITE_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional mainnet RPC for wallet reads when connected to mainnet
# VITE_MAINNET_RPC_URL=

# Partner CSV + thumbnail export (scripts/export:partner*)
# 1) npm run build:arweave-animation  → upload out/partner-export/arweave-animation.html
# 2) Put PARTNER_ARWEAVE_TX_ID (or base URL) in .env — export scripts load mint-site/.env (Vite-only vars are not enough).
# PARTNER_ARWEAVE_TX_ID=YOUR_43_CHAR_TX_ID
# Optional: template with placeholders (requires PARTNER_ARWEAVE_TX_ID if you use {txId})
# PARTNER_ANIMATION_URL_TEMPLATE=https://arweave.net/{txId}?tokenId={tokenId}
# PARTNER_ANIMATION_BASE_URL=https://arweave.net/YOUR_TX_ID
# PARTNER_CAPTURE_BASE_URL=http://127.0.0.1:5173
# PARTNER_OUTPUT_DIR=./out/partner-export
# PARTNER_CAPTURE_SIZE=1200
# PARTNER_TOKEN_START=0
# PARTNER_TOKEN_END=1439
# PARTNER_SKIP_EXISTING=1
# PARTNER_CONCURRENCY=4
