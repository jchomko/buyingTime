{
  "name": "mint-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "minify:embed": "node ./scripts/minify-embed-preview.mjs",
    "chunk:embed": "node ./scripts/chunk-embed-preview.mjs",
    "minify:embed-grid": "node ./scripts/minify-embed-grid-preview.mjs",
    "chunk:embed-grid": "node ./scripts/chunk-embed-grid-preview.mjs",
    "minify:embed-day": "node ./scripts/minify-embed-day-preview.mjs",
    "chunk:embed-day": "node ./scripts/chunk-embed-day-preview.mjs",
    "build:embeds": "npm run minify:embed && npm run chunk:embed && npm run minify:embed-grid && npm run chunk:embed-grid && npm run minify:embed-day && npm run chunk:embed-day",
    "bundle:unified-shell": "node ./scripts/bundle-unified-shell.mjs",
    "chunk:unified-shell": "node ./scripts/chunk-unified-shell.mjs",
    "build:unified-embed": "npm run bundle:unified-shell && npm run chunk:unified-shell"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.100.9",
    "bootstrap": "^5.3.8",
    "react": "^19.2.5",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "viem": "^2.48.8",
    "wagmi": "^2.19.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.47.1",
    "vite": "^8.0.9"
  }
}
